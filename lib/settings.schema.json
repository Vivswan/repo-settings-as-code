{
  "$id": "https://raw.githubusercontent.com/Vivswan/repo-settings-as-code/main/lib/settings.schema.json",
  "$ref": "#/definitions/SettingsFile",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ActionsConfig": {
      "description": "GitHub Actions permissions, routed across four endpoints by key.",
      "properties": {
        "access_level": {
          "description": "PUT /repos/{r}/actions/permissions/access (private repositories only)",
          "enum": [
            "none",
            "user",
            "organization"
          ],
          "type": "string"
        },
        "allowed_actions": {
          "description": "Which actions may run; \"selected\" pairs with selected_actions below.",
          "enum": [
            "all",
            "local_only",
            "selected"
          ],
          "type": "string"
        },
        "can_approve_pull_request_reviews": {
          "description": "Whether workflows may approve pull request reviews.",
          "type": "boolean"
        },
        "default_workflow_permissions": {
          "description": "PUT /repos/{r}/actions/permissions/workflow: the default GITHUB_TOKEN grant.",
          "enum": [
            "read",
            "write"
          ],
          "type": "string"
        },
        "enabled": {
          "description": "PUT /repos/{r}/actions/permissions: whether Actions runs at all.",
          "type": "boolean"
        },
        "selected_actions": {
          "additionalProperties": {},
          "description": "PUT /repos/{r}/actions/permissions/selected-actions (allowed_actions: selected)",
          "type": "object"
        }
      },
      "type": "object"
    },
    "AutolinkConfig": {
      "description": "One autolink reference, matched by key prefix.",
      "properties": {
        "is_alphanumeric": {
          "description": "Whether <num> also matches letters; upstream default is true.",
          "type": "boolean"
        },
        "key_prefix": {
          "description": "Text prefix that triggers the link (e.g. \"TICKET-\"), the natural key.",
          "type": "string"
        },
        "url_template": {
          "description": "Target URL template containing \"<num>\".",
          "type": "string"
        }
      },
      "required": [
        "key_prefix",
        "url_template"
      ],
      "type": "object"
    },
    "BranchConfig": {
      "description": "Classic protection for one branch.",
      "properties": {
        "name": {
          "description": "The branch name.",
          "type": "string"
        },
        "protection": {
          "anyOf": [
            {
              "additionalProperties": {},
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "description": "PUT .../protection payload; null removes protection (Probot parity)."
        }
      },
      "required": [
        "name",
        "protection"
      ],
      "type": "object"
    },
    "CodeScanningDefaultSetupConfig": {
      "description": "PATCH /repos/{r}/code-scanning/default-setup, sent verbatim.",
      "properties": {
        "languages": {
          "description": "Languages to scan, compared as a set; GitHub auto-detects when omitted.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "query_suite": {
          "description": "CodeQL query suite to run.",
          "enum": [
            "default",
            "extended"
          ],
          "type": "string"
        },
        "runner_label": {
          "description": "Runner label when runner_type is \"labeled\"; null clears it.",
          "type": [
            "string",
            "null"
          ]
        },
        "runner_type": {
          "description": "Run on GitHub-hosted (\"standard\") or labeled self-hosted runners.",
          "enum": [
            "standard",
            "labeled"
          ],
          "type": "string"
        },
        "state": {
          "description": "Turn default setup on (\"configured\") or off (\"not-configured\").",
          "enum": [
            "configured",
            "not-configured"
          ],
          "type": "string"
        },
        "threat_model": {
          "description": "Whether to model local sources as threats in addition to remote ones.",
          "enum": [
            "remote",
            "remote_and_local"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "CollaboratorConfig": {
      "description": "One direct collaborator, matched by username.",
      "properties": {
        "permission": {
          "description": "\"pull\", \"triage\", \"push\", \"maintain\", \"admin\", or a custom org role; defaults to \"push\".",
          "type": "string"
        },
        "username": {
          "description": "GitHub login, the natural key.",
          "type": "string"
        }
      },
      "required": [
        "username"
      ],
      "type": "object"
    },
    "EnvironmentConfig": {
      "description": "One deployment environment, matched by name.",
      "properties": {
        "deployment_branch_policy": {
          "anyOf": [
            {
              "properties": {
                "custom_branch_policies": {
                  "description": "Restrict to name patterns (declared separately, a known gap).",
                  "type": "boolean"
                },
                "protected_branches": {
                  "description": "Restrict to branches with protection rules.",
                  "type": "boolean"
                }
              },
              "required": [
                "protected_branches",
                "custom_branch_policies"
              ],
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "description": "Which branches may deploy; null clears the policy."
        },
        "name": {
          "description": "The environment name, the natural key.",
          "type": "string"
        },
        "prevent_self_review": {
          "description": "Whether the deployer may approve their own deployment.",
          "type": "boolean"
        },
        "reviewers": {
          "description": "Required reviewers by numeric user/team id.",
          "items": {
            "properties": {
              "id": {
                "type": "number"
              },
              "type": {
                "enum": [
                  "User",
                  "Team"
                ],
                "type": "string"
              }
            },
            "required": [
              "type",
              "id"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "wait_timer": {
          "description": "Minutes to wait before deployments proceed.",
          "type": "number"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "LabelConfig": {
      "description": "One label, matched to the live repo by name.",
      "properties": {
        "color": {
          "description": "Hex color, with or without the leading \"#\".",
          "type": "string"
        },
        "description": {
          "description": "Short explanation shown in the label picker.",
          "type": "string"
        },
        "name": {
          "description": "The label name, the natural key.",
          "type": "string"
        },
        "new_name": {
          "description": "Probot compat: rename an existing label.",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "MilestoneConfig": {
      "description": "One milestone, matched by title.",
      "properties": {
        "description": {
          "description": "Longer explanation of the milestone.",
          "type": "string"
        },
        "state": {
          "description": "Open or closed; untouched unless declared.",
          "enum": [
            "open",
            "closed"
          ],
          "type": "string"
        },
        "title": {
          "description": "The milestone title, the natural key.",
          "type": "string"
        }
      },
      "required": [
        "title"
      ],
      "type": "object"
    },
    "PagesConfig": {
      "description": "GitHub Pages site configuration; use `pages: null` to disable the site.",
      "properties": {
        "build_type": {
          "description": "\"workflow\" (GitHub Actions) or \"legacy\" (branch).",
          "enum": [
            "workflow",
            "legacy"
          ],
          "type": "string"
        },
        "cname": {
          "description": "Custom domain; null removes it.",
          "type": [
            "string",
            "null"
          ]
        },
        "https_enforced": {
          "description": "Whether HTTPS is enforced for the site.",
          "type": "boolean"
        },
        "source": {
          "description": "The update PUT requires both branch and path when source is sent.",
          "properties": {
            "branch": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "branch"
          ],
          "type": "object"
        }
      },
      "type": "object"
    },
    "RulesetConfig": {
      "description": "One repository ruleset, matched to the live repo by name.",
      "properties": {
        "bypass_actors": {
          "description": "Who may bypass the ruleset, passed through verbatim.",
          "items": {
            "additionalProperties": {},
            "type": "object"
          },
          "type": "array"
        },
        "conditions": {
          "description": "Which refs the ruleset covers.",
          "properties": {
            "ref_name": {
              "description": "Short ref names are auto-prefixed (staging -> refs/heads/staging).",
              "properties": {
                "exclude": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "include": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "enforcement": {
          "description": "\"active\", \"evaluate\", or \"disabled\". Created rulesets default to \"active\".",
          "type": "string"
        },
        "name": {
          "description": "The ruleset name, the natural key.",
          "type": "string"
        },
        "rules": {
          "description": "Rule list, passed through verbatim (future rule types included).",
          "items": {
            "properties": {
              "parameters": {
                "additionalProperties": {},
                "type": "object"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "type"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "target": {
          "description": "What the ruleset applies to; defaults to \"branch\" upstream.",
          "enum": [
            "branch",
            "tag",
            "push"
          ],
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "SettingsFile": {
      "description": "One settings.yml document: every top-level section is optional.",
      "properties": {
        "actions": {
          "$ref": "#/definitions/ActionsConfig",
          "description": "GitHub Actions permissions for the repository."
        },
        "autolinks": {
          "description": "Autolink references; undeclared ones are DELETED.",
          "items": {
            "$ref": "#/definitions/AutolinkConfig"
          },
          "type": "array"
        },
        "branches": {
          "description": "Classic branch protection per branch.",
          "items": {
            "$ref": "#/definitions/BranchConfig"
          },
          "type": "array"
        },
        "code_scanning_default_setup": {
          "$ref": "#/definitions/CodeScanningDefaultSetupConfig",
          "description": "Code scanning default setup (CodeQL)."
        },
        "collaborators": {
          "description": "Direct collaborators; undeclared ones are REMOVED (owner never touched).",
          "items": {
            "$ref": "#/definitions/CollaboratorConfig"
          },
          "type": "array"
        },
        "environments": {
          "description": "Deployment environments, upserted by name.",
          "items": {
            "$ref": "#/definitions/EnvironmentConfig"
          },
          "type": "array"
        },
        "labels": {
          "description": "Issue/PR labels; undeclared labels are DELETED (Probot parity).",
          "items": {
            "$ref": "#/definitions/LabelConfig"
          },
          "type": "array"
        },
        "milestones": {
          "description": "Milestones, upserted by title; undeclared ones are kept.",
          "items": {
            "$ref": "#/definitions/MilestoneConfig"
          },
          "type": "array"
        },
        "pages": {
          "anyOf": [
            {
              "$ref": "#/definitions/PagesConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "GitHub Pages configuration; null disables Pages on the repository."
        },
        "repository": {
          "additionalProperties": {},
          "description": "Repo fields sent verbatim to PATCH /repos/{r}, plus the special keys below.",
          "type": "object"
        },
        "rulesets": {
          "description": "Repository rulesets, upserted by name; undeclared ones are kept.",
          "items": {
            "$ref": "#/definitions/RulesetConfig"
          },
          "type": "array"
        },
        "teams": {
          "description": "Org team access to the repo; skipped on personal accounts.",
          "items": {
            "$ref": "#/definitions/TeamConfig"
          },
          "type": "array"
        },
        "workflows": {
          "description": "Per-workflow enable/disable state; undeclared workflows are untouched.",
          "items": {
            "$ref": "#/definitions/WorkflowConfig"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "TeamConfig": {
      "description": "One org team's access to the repository, matched by team slug.",
      "properties": {
        "name": {
          "description": "The team slug, the natural key.",
          "type": "string"
        },
        "permission": {
          "description": "Same vocabulary as collaborators; defaults to \"push\".",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "WorkflowConfig": {
      "description": "One workflow's enable/disable state, keyed by its file path.",
      "properties": {
        "path": {
          "description": "Full \".github/workflows/ci.yml\" or the bare \"ci.yml\" file name.",
          "type": "string"
        },
        "state": {
          "description": "Desired state; every live disabled_* variant counts as \"disabled\".",
          "enum": [
            "active",
            "disabled"
          ],
          "type": "string"
        }
      },
      "required": [
        "path",
        "state"
      ],
      "type": "object"
    }
  }
}