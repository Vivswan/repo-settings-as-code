{
  "name": "repo-settings-as-code",
  "private": true,
  "description": "GitHub Action applying declarative repository settings: rulesets, labels, branch protection, and more.",
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test && bun run build:check",
    "lint": "bun x biome ci .",
    "lint:fix": "bun x biome check --write .",
    "typecheck": "bun x tsc -p .",
    "test": "bun test",
    "build": "bun build src/main.ts --target=node --outfile lib/index.js",
    "build:check": "bun run build && git diff --exit-code lib/",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@octokit/openapi-types": "^27.0.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "typescript": "^7.0.2"
  }
}
