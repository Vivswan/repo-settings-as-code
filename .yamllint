# Shared yamllint configuration from Vivswan/repo-platform.
# The key win is key-duplicates: YAML loaders silently keep the last value,
# so nothing else in the CI gate would catch a duplicated key.
extends: default

ignore:
  - .venv
  - node_modules
  - dist
  - build
  - coverage
  # Machine-generated by copier (pyyaml emits unindented sequences, which the
  # default indentation rule rejects); the validator still YAML-parses it.
  - .copier-answers.yml

rules:
  document-start: disable # no --- preamble required
  line-length: disable # workflow `if:` expressions run long
  truthy:
    check-keys: false # GitHub workflows' `on:` key is fine
  comments:
    min-spaces-from-content: 1
